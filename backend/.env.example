PORT=5000

# Firebase Web API Key (required for login). From Firebase Console → Project settings → General → Web API Key.
# If login fails with "API key" error: in Google Cloud Console → APIs & Services → Credentials → your key → set "Application restrictions" to "None" for server use.
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# Email (for verification links). Use Gmail App Password or another SMTP service.
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=VaxAlert <your-email@gmail.com>

# Base URL of this API (used in verification email link)
API_BASE_URL=http://localhost:5000
# Where to redirect after email verification (your login page)
LOGIN_PAGE_URL=http://localhost:5500/frontend/login.html
